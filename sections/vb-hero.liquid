{{ 'vb-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_image = section.settings.hero_image
  assign hero_image_mobile = section.settings.hero_image_mobile | default: section.settings.hero_image
  assign overlay_opacity = section.settings.overlay_opacity | default: 35
  assign text_alignment = section.settings.text_alignment | default: 'left'
  assign content_max_width = section.settings.content_max_width | default: 'narrow'
-%}

<section
  class="vb-hero vb-hero--align-{{ text_alignment }} vb-hero--width-{{ content_max_width }}"
  aria-label="{{ section.settings.aria_label | default: 'Hero' | escape }}"
  {% if hero_image == blank %}data-no-image="true"{% endif %}
>
  {%- if hero_image != blank -%}
    <div class="vb-hero__media" aria-hidden="true">
      <picture>
        {%- if hero_image_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="{{ hero_image_mobile | image_url: width: 750 }} 1x, {{ hero_image_mobile | image_url: width: 1500 }} 2x"
          >
        {%- endif -%}
        <source
          media="(min-width: 750px)"
          srcset="{{ hero_image | image_url: width: 1500 }} 1x, {{ hero_image | image_url: width: 3000 }} 2x"
        >
        <img
          src="{{ hero_image | image_url: width: 1500 }}"
          alt="{{ hero_image.alt | default: section.settings.heading | escape }}"
          width="{{ hero_image.width }}"
          height="{{ hero_image.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        >
      </picture>
      <div
        class="vb-hero__overlay"
        style="--vb-hero-overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};"
      ></div>
    </div>
  {%- endif -%}

  <div class="vb-hero__inner">
    <div class="vb-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="vb-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="vb-hero__heading">{{ section.settings.heading | newline_to_br }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="vb-hero__sub">{{ section.settings.subheading | newline_to_br }}</p>
      {%- endif -%}

      {%- if section.settings.primary_cta_label != blank and section.settings.primary_cta_link != blank -%}
        <div class="vb-hero__ctas">
          <a class="vb-btn vb-btn--primary" href="{{ section.settings.primary_cta_link }}">
            {{ section.settings.primary_cta_label | escape }}
          </a>
          {%- if section.settings.secondary_cta_label != blank and section.settings.secondary_cta_link != blank -%}
            <a class="vb-btn vb-btn--ghost" href="{{ section.settings.secondary_cta_link }}">
              {{ section.settings.secondary_cta_label | escape }}
              <span class="vb-btn__arrow" aria-hidden="true">→</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="vb-hero__trust" role="list">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'trust_metric' -%}
                <div class="vb-hero__trust-item" role="listitem" {{ block.shopify_attributes }}>
                  {%- if block.settings.metric_value != blank -%}
                    <span class="vb-hero__trust-value">{{ block.settings.metric_value | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.metric_label != blank -%}
                    <span class="vb-hero__trust-label">{{ block.settings.metric_label | escape }}</span>
                  {%- endif -%}
                </div>
              {%- when 'trust_text' -%}
                <div class="vb-hero__trust-item vb-hero__trust-item--text" role="listitem" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="vb-hero__trust-icon" aria-hidden="true">{{ block.settings.icon | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <span class="vb-hero__trust-text">{{ block.settings.text | escape }}</span>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VB Hero",
  "tag": "section",
  "class": "vb-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Desktop hero image",
      "info": "Recommended: 3000×1500 px (2× crisp on retina). JPG/WebP. Subject left-of-centre so text reads on the right. Leave empty for a clean tinted hero."
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Mobile hero image (optional)",
      "info": "Recommended: 1500×1500 px square or 4:5 portrait. If empty, desktop image is used."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay strength",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 35,
      "info": "Darkens the image behind the text for legibility. 0 = none, 70 = strong."
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (small line above headline)",
      "default": "Patented acid-resistant delivery"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Headline",
      "default": "Probiotics that actually reach the gut.",
      "info": "Press Enter for line breaks. Keep under 12 words for impact."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Most probiotic capsules dissolve in stomach acid before live cultures arrive. Velobiotics survives the journey, releases in the small intestine, and lets the live cultures do their job."
    },
    {
      "type": "header",
      "content": "Calls to action"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary CTA label",
      "default": "Shop the range"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "How it works"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "content_max_width",
      "label": "Content width",
      "options": [
        { "value": "narrow", "label": "Narrow (focused)" },
        { "value": "wide", "label": "Wide (cinematic)" }
      ],
      "default": "narrow"
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA landmark label",
      "default": "Hero",
      "info": "Visible only to screen readers; describes this region."
    }
  ],
  "blocks": [
    {
      "type": "trust_metric",
      "name": "Trust metric (number + label)",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "metric_value",
          "label": "Number / value",
          "default": "300,000+"
        },
        {
          "type": "text",
          "id": "metric_label",
          "label": "Label",
          "default": "happy customers"
        }
      ]
    },
    {
      "type": "trust_text",
      "name": "Trust text (icon + line)",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or short character)",
          "default": "★"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "4.8 average rating"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VB Hero",
	   "category": "Velobiotics",
      "blocks": [
        { "type": "trust_metric", "settings": { "metric_value": "300,000+", "metric_label": "happy customers" } },
        { "type": "trust_metric", "settings": { "metric_value": "4.8", "metric_label": "average rating" } },
        { "type": "trust_metric", "settings": { "metric_value": "30B", "metric_label": "CFU per dose" } },
        { "type": "trust_text", "settings": { "icon": "🇿🇦", "text": "Lab-tested in South Africa" } }
      ]
    }
  ]
}
{% endschema %}